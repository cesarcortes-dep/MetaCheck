# Canonical production URL (used for metadataBase, robots.txt, sitemap.xml).
# Falls back to https://$VERCEL_URL (preview deploys) and then to http://localhost:3000 (local dev).
NEXT_PUBLIC_SITE_URL=https://meta-check-two.vercel.app

# Upstash Redis — required in production for rate limiting on /api/analyze.
# When missing in dev, rate limiting is disabled (with a warning in the server log).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
